# API 서버 URL
NEXT_PUBLIC_API_URL=http://localhost:8080/graphql

# 앱 URL (파트너 대시보드)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# 블록픽 앱 URL (유저향)
NEXT_PUBLIC_BLOCKPICK_APP_URL=http://localhost:3000

# JWT 토큰 스토리지 키 (변경 금지)
NEXT_PUBLIC_TOKEN_KEY=partner_access_token
NEXT_PUBLIC_REFRESH_TOKEN_KEY=partner_refresh_token

# 환경
NODE_ENV=development
